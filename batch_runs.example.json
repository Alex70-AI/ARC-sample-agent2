{
  "stop_on_failure": true,
  "defaults": {
    "workspace": "dev"
  },
  "stages": [
    {
      "name": "sequential-full-sessions",
      "runs": [
        {
          "name": "openai-gpt-4.1",
          "provider": "openai",
          "model": "gpt-4.1-2025-04-14",
          "workspace": "dev-gpt41"
        },
        {
          "name": "openrouter-gpt-oss-120b",
          "provider": "openrouter",
          "model": "openai/gpt-oss-120b",
          "workspace": "dev-oss120b"
        }
      ]
    },
    {
      "name": "parallel-single-task-checks",
      "parallel": true,
      "max_parallel": 2,
      "runs": [
        {
          "name": "gpt41-notification-raise",
          "provider": "openai",
          "model": "gpt-4.1-2025-04-14",
          "workspace": "dev-gpt41-notification",
          "spec": "notification_raise"
        },
        {
          "name": "oss120b-notification-raise",
          "provider": "openrouter",
          "model": "openai/gpt-oss-120b",
          "workspace": "dev-oss120b-notification",
          "spec": "notification_raise"
        }
      ]
    }
  ]
}
